# ==============================================
# @excalidrow/api environment variables
# ==============================================

NODE_ENV=development
PORT=4000

# ---- MongoDB ----
MONGO_URI=mongodb://127.0.0.1:27017/excalidrow

# ---- JWT ----
# IMPORTANT: replace with random 64+ char strings in real use.
JWT_ACCESS_SECRET=replace_me_with_a_64_char_random_string_for_access_tokens_xxxxxx
JWT_REFRESH_SECRET=replace_me_with_a_64_char_random_string_for_refresh_tokens_xxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- CORS ----
WEB_ORIGIN=http://localhost:5173

# ---- Storage (relative to repo root) ----
UPLOAD_ROOT=../../uploads
MAX_UPLOAD_BYTES=26214400

# ---- Rate limit ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ---- Logging ----
LOG_LEVEL=info
